{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/core/**/*.ts",
    "src/features/**/services/*.ts",
    "src/shared/utils/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.d.ts",
    "**/index.ts",
    "**/node_modules/**"
  ],
  "out": "docs/api",
  "name": "IMMERSA 3D Scene Viewer API",
  "includeVersion": true,
  "readme": "none",
  "plugin": [],
  "options": {
    "excludePrivate": true,
    "excludeProtected": false,
    "gitRevision": "main"
  }
}
